FROM --platform=linux/arm64 ghcr.io/openclaw/openclaw:latest

USER root

RUN apt-get update && apt-get install -y --no-install-recommends curl python3 python3-pip python3-venv \
    && rm -rf /var/lib/apt/lists/*

COPY agent-entrypoint.sh /home/node/entrypoint.sh
COPY whatsapp-linker.sh /home/node/whatsapp-linker.sh
COPY whatsapp-linker.mjs /home/node/whatsapp-linker.mjs
COPY whatsapp-relay.mjs /home/node/whatsapp-relay.mjs
COPY agent-config.py /home/node/agent-config.py
RUN sed -i 's/\r$//' /home/node/entrypoint.sh /home/node/whatsapp-linker.sh \
    && chmod +x /home/node/entrypoint.sh /home/node/whatsapp-linker.sh \
    && mkdir -p /home/node/.openclaw \
    && chown node:node /home/node/.openclaw

USER node
WORKDIR /home/node

# Pre-install WhatsApp channel plugin so the agent picks up linked credentials on restart.
# `timeout 60` works around a known openclaw bug where the process hangs after a successful
# install and never calls process.exit() — the plugin IS installed, the process just won't quit.
RUN timeout -k 5 60 openclaw plugins install @openclaw/whatsapp || true

# Install Baileys for the direct WhatsApp linker script.
# We use Baileys directly (bypassing `openclaw channels login`) because the OpenClaw
# CLI renders the QR as Unicode art and never emits the raw QR string to stdout.
# Credentials are stored at ${OPENCLAW_HOME}/credentials/whatsapp/default/ — the same
# path that OpenClaw's @openclaw/whatsapp plugin expects on the agent side.
RUN npm install @whiskeysockets/baileys

EXPOSE 18789

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
  CMD curl -fsS http://127.0.0.1:18789/healthz || exit 1

ENTRYPOINT ["/home/node/entrypoint.sh"]