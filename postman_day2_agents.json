  "item": [
    {
      "name": "Agents API",
      "item": [
        {
          "name": "1. Launch Finance Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Agent returned', () => {",
                  "  pm.expect(res.agent).to.be.an('object');",
                  "  pm.expect(res.agent.type).to.eql('finance');",
                  "  pm.expect(res.agent.status).to.be.oneOf(['active', 'starting']);",
                  "});",
                  "if (res.agent) {",
                  "  pm.collectionVariables.set('agentId', res.agent.id);",
                  "  console.log('Agent ID saved:', res.agent.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Cookie", "value": "better-auth.session_token={{sessionToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"type\": \"finance\" }"
            },
            "url": {
              "raw": "{{baseUrl}}/api/agents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents"]
            }
          }
        },
        {
