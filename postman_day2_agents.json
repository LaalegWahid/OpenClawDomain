          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Cookie", "value": "better-auth.session_token={{sessionToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/agents/{{agentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents", "{{agentId}}"]
            }
          }
        },
        {
          "name": "10. Verify Agent Stopped",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Agent status is stopped', () => {",
                  "  pm.expect(res.agent.status).to.eql('stopped');",
                  "  pm.expect(res.agent.containerId).to.be.null;",
                  "});",
                  "pm.test('Stop activity logged', () => {",
                  "  const stopActivity = res.activities.find(a => a.type === 'stop');",
                  "  pm.expect(stopActivity).to.not.be.undefined;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "better-auth.session_token={{sessionToken}}" }
