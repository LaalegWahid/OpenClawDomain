        {
          "name": "6. List All Agents",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Agents array returned', () => {",
                  "  pm.expect(res.agents).to.be.an('array');",
                  "  pm.expect(res.agents.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Each agent has required fields', () => {",
                  "  res.agents.forEach(a => {",
                  "    pm.expect(a).to.have.property('id');",
                  "    pm.expect(a).to.have.property('type');",
                  "    pm.expect(a).to.have.property('name');",
                  "    pm.expect(a).to.have.property('status');",
                  "  });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
