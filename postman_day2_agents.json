  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "sessionToken",
      "value": "YOUR_SESSION_TOKEN_HERE"
    },
    {
      "key": "webhookSecret",
      "value": "071efae27a8c8ab9e3f210468a09eb297113b6a80c7b29507aec2992359c31bc"
    },
    {
      "key": "agentId",
      "value": ""
    },
